# ============================================
# REQUIRED API KEYS FOR SEO AUDIT
# ============================================

# Google PageSpeed Insights API (REQUIRED for Core Web Vitals)
# Get it free at: https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PAGESPEED_API_KEY=""

# ============================================
# OPTIONAL: Trigger.dev (for site crawling)
# ============================================
# Get your key at: https://cloud.trigger.dev
TRIGGER_SECRET_KEY="tr_dev_..."

# ============================================
# OPTIONAL: OpenAI (for AI features)
# ============================================
# Get your key at: https://platform.openai.com/api-keys
# Used for: Content generation, Voice summaries, AI ranking strategies
OPENAI_API_KEY=""

# ============================================
# OPTIONAL: Additional APIs
# ============================================

# Google Places API (for GBP Audit feature)
GOOGLE_PLACES_API_KEY=""

# Moz API (for backlinks analysis - optional)
MOZ_API_KEY=""
MOZ_ACCESS_ID=""

# ============================================
# DATABASE (optional - for persistent storage)
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/seo_audit?schema=public"

# ============================================
# STORAGE (optional - for screenshots)
# ============================================
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
STORAGE_BUCKET=""
STORAGE_ENDPOINT=""

# ============================================
# SUPABASE AUTH (optional)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ============================================
# CLERK AUTHENTICATION (required)
# ============================================
# Get your keys at: https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/workspaces"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/workspaces"

# ============================================
# WORDPRESS INTEGRATION
# ============================================
# Your WordPress site URL
WORDPRESS_URL="https://your-wordpress-site.com"
# WordPress plugin API key (get from SEO AutoFix plugin settings)
WORDPRESS_API_KEY=""

# ============================================
# APP CONFIG
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ============================================
# STRIPE BILLING (for subscription management)
# ============================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_AGENCY="price_..."
STRIPE_PRICE_WHITE_LABEL="price_..."

# ============================================
# EMAIL (Resend for email engine)
# ============================================
RESEND_API_KEY="re_..."

# ============================================
# ENCRYPTION (for API keys and secrets)
# ============================================
ENCRYPTION_KEY="your-32-character-encryption-key-here"
